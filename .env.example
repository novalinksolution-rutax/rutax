# Copia este archivo a .env.local y completa con tus valores.
# NUNCA commitees .env.local — ya está en .gitignore.

# Supabase del proyecto (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo para jobs/servidor (RLS bypass) — nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# Zona horaria de la app (Santiago)
TZ=America/Santiago
