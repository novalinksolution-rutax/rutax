# Copia este archivo a .env.local y completa con tus valores.
# NUNCA commitees .env.local — ya está en .gitignore.
#
# Para el entorno local/staging:
#   cp .env.example .env.local
#   # Completa las variables de Supabase (ver abajo) y arranca con:
#   npx supabase start          # levanta Postgres+Auth+Studio locales
#   npx supabase db push        # aplica migraciones
#   npx supabase db seed        # carga datos de demo
#   npm run dev                 # Next.js (http://localhost:3000)
#   npx inngest-cli@latest dev  # Inngest Dev Server (http://localhost:8288)

# Supabase del proyecto (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo para jobs/servidor (RLS bypass) — nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# Zona horaria de la app (Santiago)
TZ=America/Santiago

# -----------------------------------------------------------------------------
# integraciones — mecanismo de cifrado de secretos (src/modules/integraciones/secretos)
# -----------------------------------------------------------------------------
# Clave maestra simétrica AES-256 (32 bytes) codificada en base64. Cifra/descifra
# certificados, credenciales DTE y tokens OAuth ML antes de persistirlos en
# identidad.secretos_cifrados. Generar con, p.ej.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Gestionar vía el secret manager del despliegue (Vercel/Supabase) — JAMÁS
# comprometer al repo ni loguear su valor. Rotación: añade
# SECRETOS_CLAVE_CIFRADO_B64_<kid> y fija SECRETOS_CIFRADO_KID al nuevo kid.
SECRETOS_CLAVE_CIFRADO_B64=
# Identificador de la clave activa (default "v1" si se omite). Solo cambia al rotar.
SECRETOS_CIFRADO_KID=

# -----------------------------------------------------------------------------
# URL pública canónica de la app (para el redirect_uri de OAuth)
# -----------------------------------------------------------------------------
# Dominio público con el que la app se expone (HTTPS). Se usa para construir el
# `redirect_uri` de OAuth de ML y las redirecciones del callback. DEBE coincidir
# EXACTO con la redirect URI registrada en el DevCenter de ML.
# - Producción: https://tu-dominio (p. ej. https://rutax.vercel.app)
# - Prueba local con túnel: la URL HTTPS de cloudflared/ngrok (cambia en cada
#   reinicio del túnel; actualízala aquí y reinicia `npm run dev`).
# Si se deja vacía, se deriva del host de la petición (sirve solo si el host
# público llega tal cual, sin túnel de por medio).
APP_PUBLIC_URL=

# -----------------------------------------------------------------------------
# integraciones — puerto OAuth Mercado Libre (src/modules/integraciones/ml)
# -----------------------------------------------------------------------------
# Credenciales de la app de ML (de plataforma — una sola app sirve a todos los
# couriers/sellers que se conectan). Crear en developers.mercadolibre.cl.
ML_APP_CLIENT_ID=
ML_APP_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# integraciones — webhooks de Mercado Libre
# -----------------------------------------------------------------------------
# OBSOLETO / NO USAR: ML marketplace NO firma sus notificaciones (verificado en
# vivo: sin header `x-signature`). El esquema HMAC con clave secreta es de
# Mercado Pago, otro producto. Las notificaciones de ML se validan por
# `application_id` + se consulta el recurso con el token del seller (ver
# src/app/api/webhooks/ml/shipments/route.ts). Esta variable quedó sin uso.
# WEBHOOKS_ML_SECRET=

# -----------------------------------------------------------------------------
# jobs — Inngest (orquestador de jobs en segundo plano)
# -----------------------------------------------------------------------------
# Clave para publicar eventos desde el servidor hacia el servidor de Inngest.
# Obtener en: app.inngest.com > Settings > Event Keys.
# En desarrollo local con Inngest Dev Server (`npx inngest-cli dev`) puede
# dejarse vacía — el Dev Server acepta cualquier clave o ninguna.
# NUNCA loguear su valor.
INNGEST_EVENT_KEY=

# Clave de firma para que Inngest valide que las peticiones al endpoint
# `/api/inngest` vienen realmente del servidor de Inngest (evita replay attacks).
# Obtener en: app.inngest.com > Settings > Signing Key.
# En desarrollo local puede omitirse.
# NUNCA loguear su valor.
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# integraciones — proveedor DTE (sandbox local/staging solamente)
# -----------------------------------------------------------------------------
# En el entorno local la integración DTE es un STUB (simplefactura.ts).
# NO se emiten DTEs reales al SII. Las variables de abajo son solo para
# documentar qué se necesitará al conectar el proveedor real en producción.
# NUNCA escribir credenciales reales en este archivo ni en el repo.
#
# URL base del sandbox del proveedor DTE elegido:
DTE_SANDBOX_BASE_URL=
# RUT del emisor (del courier) en el sistema del proveedor:
DTE_SANDBOX_RUT_EMISOR=
# Credenciales del proveedor en sandbox (NO usar en logs ni en URLs):
DTE_SANDBOX_API_KEY=
# Indicador de modo sandbox (valor: "true" — evita emitir DTEs reales):
DTE_SANDBOX_MODE=true
