# Copia este archivo a .env.local y completa con tus valores.
# NUNCA commitees .env.local — ya está en .gitignore.

# Supabase del proyecto (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo para jobs/servidor (RLS bypass) — nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# Zona horaria de la app (Santiago)
TZ=America/Santiago

# -----------------------------------------------------------------------------
# integraciones — mecanismo de cifrado de secretos (src/modules/integraciones/secretos)
# -----------------------------------------------------------------------------
# Clave maestra simétrica AES-256 (32 bytes) codificada en base64. Cifra/descifra
# certificados, credenciales DTE y tokens OAuth ML antes de persistirlos en
# identidad.secretos_cifrados. Generar con, p.ej.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Gestionar vía el secret manager del despliegue (Vercel/Supabase) — JAMÁS
# comprometer al repo ni loguear su valor. Rotación: añade
# SECRETOS_CLAVE_CIFRADO_B64_<kid> y fija SECRETOS_CIFRADO_KID al nuevo kid.
SECRETOS_CLAVE_CIFRADO_B64=
# Identificador de la clave activa (default "v1" si se omite). Solo cambia al rotar.
SECRETOS_CIFRADO_KID=

# -----------------------------------------------------------------------------
# integraciones — puerto OAuth Mercado Libre (src/modules/integraciones/ml)
# -----------------------------------------------------------------------------
# Credenciales de la app de ML (de plataforma — una sola app sirve a todos los
# couriers/sellers que se conectan). Crear en developers.mercadolibre.cl.
ML_APP_CLIENT_ID=
ML_APP_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# integraciones — webhooks de Mercado Libre
# -----------------------------------------------------------------------------
# Secreto compartido para validar la firma HMAC-SHA256 del header `x-signature`
# que ML incluye en cada notificación de webhook (topic `shipments`).
# Se configura en la consola de la app de ML (Developers > Notifications).
# NUNCA loguear su valor.
WEBHOOKS_ML_SECRET=

# -----------------------------------------------------------------------------
# jobs — Inngest (orquestador de jobs en segundo plano)
# -----------------------------------------------------------------------------
# Clave para publicar eventos desde el servidor hacia el servidor de Inngest.
# Obtener en: app.inngest.com > Settings > Event Keys.
# En desarrollo local con Inngest Dev Server (`npx inngest-cli dev`) puede
# dejarse vacía — el Dev Server acepta cualquier clave o ninguna.
# NUNCA loguear su valor.
INNGEST_EVENT_KEY=

# Clave de firma para que Inngest valide que las peticiones al endpoint
# `/api/inngest` vienen realmente del servidor de Inngest (evita replay attacks).
# Obtener en: app.inngest.com > Settings > Signing Key.
# En desarrollo local puede omitirse.
# NUNCA loguear su valor.
INNGEST_SIGNING_KEY=
